      </ImageView>
      <ImageView fitHeight="50.0" fitWidth="100.0" layoutX="429.0" layoutY="142.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../../pictures/board.png" />
         </image>
      </ImageView>
      <Label fx:id="roundLabel" layoutX="306.0" layoutY="154.0" prefHeight="25.0" prefWidth="76.0" text="Round: 1/10" textFill="#944b1a">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <Label fx:id="winsLabel" layoutX="454.0" layoutY="159.0" text=" Wins: 0" />
      <Label fx:id="lossesLabel" layoutX="573.0" layoutY="159.0" text="Losses: 0" />
      <Label fx:id="timerLabel" layoutX="684.0" layoutY="154.0" text="Time: 90">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
