<!-- If you have buttons or gridpanes, they go here -->

<AnchorPane prefHeight="797.0" prefWidth="800.0" style="-fx-background-image: url('/H:\hangman-student\src\main\resources\pictures/Bg');" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.quentincillierre.hangman.controller.GameController">
   <children>
      <ImageView fitHeight="800.0" fitWidth="803.0" pickOnBounds="true" preserveRatio="true" style="-fx-background-image: url('/H:\hangman-student\src\main\resources\pictures/Bg.png');;">
         <image>
            <Image url="@../../../../pictures/Bg.png" />
         </image>
      </ImageView>
      <!-- 1. Hangman Image Area (Centered near top) -->
      <ImageView fx:id="hangmanImageView" fitHeight="417.0" fitWidth="251.0" layoutX="30.0" layoutY="99.0" pickOnBounds="true" preserveRatio="true" />
      <ImageView fitHeight="50.0" fitWidth="100.0" layoutX="298.0" layoutY="141.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../../pictures/board.png" />
         </image>
      </ImageView>
      <ImageView fitHeight="89.0" fitWidth="480.0" layoutX="208.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../../pictures/Hangman%20Game.png" />
         </image>
      </ImageView>
      <ImageView fitHeight="269.0" fitWidth="470.0" layoutX="285.0" layoutY="236.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../../pictures/board.png" />
         </image>
      </ImageView>
      <ImageView fitHeight="258.0" fitWidth="521.0" layoutX="261.0" layoutY="154.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../../pictures/clue.png" />
         </image>
      </ImageView>
      <ImageView fitHeight="50.0" fitWidth="100.0" layoutX="671.0" layoutY="141.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../../pictures/board.png" />
         </image>
      </ImageView>
      
            <!-- 2. Clue Label -->
      <Label fx:id="clueLabel" alignment="CENTER" layoutX="298.0" layoutY="279.0" prefHeight="40.0" prefWidth="457.0" text=" Clue of the word!" textAlignment="CENTER" textFill="#4A5568" wrapText="true">
         <font>
            <Font name="System Italic" size="18.0" />
         </font>
      </Label>
      
      <!-- 3. Hidden Word Slots (_ _ _ _) -->
      <Label fx:id="wordLabel" alignment="CENTER" layoutX="239.0" layoutY="360.0" prefHeight="40.0" prefWidth="554.0" text="_ _ _ _ _" textAlignment="CENTER" textFill="#2D3748">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Label>
      
      <!-- 4. Win/Lose Result Status -->
      <Label fx:id="resultLabel" alignment="CENTER" layoutX="362.0" layoutY="421.0" prefHeight="40.0" prefWidth="309.0" textAlignment="CENTER">
         <font>
            <Font name="System Bold Italic" size="22.0" />
         </font>
      </Label>
      <Button fx:id="restartButton" layoutX="475.0" layoutY="503.0" mnemonicParsing="false" onAction="#handleRestart" prefHeight="25.0" prefWidth="91.0" text="Next Round" />
      
      <!-- 5. Keyboard Grid (Near bottom) -->
      <GridPane fx:id="keyboardGrid" alignment="BASELINE_CENTER" hgap="10.0" layoutX="172.0" layoutY="564.0" prefHeight="200.0" prefWidth="457.0" vgap="10.0">
         <effect>
            <Glow />
         </effect>
         <opaqueInsets>
            <Insets />
         </opaqueInsets>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor></GridPane>
      <ImageView fitHeight="50.0" fitWidth="100.0" layoutX="551.0" layoutY="142.0" pickOnBounds="true" preserveRatio="true">
         <image>
