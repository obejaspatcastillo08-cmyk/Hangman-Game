<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.Glow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.text.Font?>

<!-- If you have buttons or gridpanes, they go here -->

<AnchorPane prefHeight="797.0" prefWidth="800.0" style="-fx-background-image: url('/H:\hangman-student\src\main\resources\pictures/Bg');" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.quentincillierre.hangman.controller.GameController">
   <children>
      <ImageView fitHeight="802.0" fitWidth="800.0" layoutX="1.0" pickOnBounds="true" preserveRatio="true" style="-fx-background-image: url('/H:\hangman-student\src\main\resources\pictures/Bg.png');;">
         <image>
            <Image url="@../../../../pictures/Bg.png" />
         </image>
      </ImageView>
      <!-- 1. Hangman Image Area (Centered near top) -->
      <ImageView fx:id="hangmanImageView" fitHeight="400.0" fitWidth="260.0" layoutX="22.0" layoutY="369.0" pickOnBounds="true" preserveRatio="true" />
      <ImageView fitHeight="50.0" fitWidth="100.0" layoutX="22.0" layoutY="121.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../../pictures/board.png" />
         </image>
      </ImageView>
      <ImageView fitHeight="133.0" fitWidth="490.0" layoutX="155.0" layoutY="-1.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../../pictures/Hangman%20Game.png" />
         </image>
      </ImageView>
      <ImageView fitHeight="244.0" fitWidth="450.0" layoutX="290.0" layoutY="187.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../../pictures/board.png" />
         </image>
      </ImageView>
      <ImageView fitHeight="209.0" fitWidth="444.0" layoutX="306.0" layoutY="140.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../../pictures/clue.png" />
         </image>
      </ImageView>
      <ImageView fitHeight="50.0" fitWidth="150.0" layoutX="645.0" layoutY="120.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../../pictures/board.png" />
         </image>
      </ImageView>
      
      <!-- 2. Clue Label -->
      <Label fx:id="clueLabel" alignment="CENTER" layoutX="303.0" layoutY="247.0" prefHeight="18.0" prefWidth="425.0" text=" Clue of the word!" textAlignment="CENTER" textFill="#4A5568" wrapText="true">
         <font>
            <Font name="System Italic" size="18.0" />
         </font>
      </Label>
      
      <!-- 3. Hidden Word Slots (_ _ _ _) -->
      <Label fx:id="wordLabel" alignment="CENTER" layoutX="229.0" layoutY="310.0" prefHeight="40.0" prefWidth="573.0" text="_ _ _ _ _" textAlignment="CENTER" textFill="#2D3748">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Label>
      
      <!-- 4. Win/Lose Result Status -->
      <Label fx:id="resultLabel" alignment="CENTER" layoutX="369.0" layoutY="369.0" prefHeight="32.0" prefWidth="313.0" textAlignment="CENTER">
         <font>
            <Font name="System Bold Italic" size="22.0" />
         </font>
      </Label>
      <Button fx:id="restartButton" layoutX="471.0" layoutY="447.0" mnemonicParsing="false" onAction="#handleRestart" text="Next Round" visible="false" />
      
      <!-- 5. Keyboard Grid (Near bottom) -->
      <GridPane fx:id="keyboardGrid" alignment="BASELINE_CENTER" hgap="10.0" layoutX="318.0" layoutY="490.0" prefHeight="186.0" prefWidth="396.0" vgap="10.0">
         <effect>
            <Glow />
         </effect>
         <opaqueInsets>
            <Insets />
         </opaqueInsets>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor></GridPane>
      <ImageView fitHeight="50.0" fitWidth="98.0" layoutX="22.0" layoutY="245.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../../pictures/board.png" />
         </image>
      </ImageView>
      <ImageView fitHeight="50.0" fitWidth="105.0" layoutX="22.0" layoutY="184.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../../pictures/board.png" />
         </image>
      </ImageView>
      <Label fx:id="roundLabel" layoutX="30.0" layoutY="134.0" prefHeight="25.0" prefWidth="76.0" text="Round: 1/10" textFill="#944b1a">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <Label fx:id="winsLabel" layoutX="44.0" layoutY="200.0" text=" Wins: 0" />
      <Label fx:id="lossesLabel" layoutX="39.0" layoutY="261.0" text="Losses: 0" />
      <Label fx:id="timerLabel" layoutX="658.0" layoutY="133.0" text="Time: 90">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
